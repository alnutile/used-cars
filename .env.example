# Client-side (VITE_ vars are PUBLIC — they ship in the browser bundle).
# The Supabase anon/publishable key is safe here. service_role NEVER goes in a VITE_ var.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only (Supabase Edge Function secrets — set via `supabase secrets set`,
# never in client code, never committed):
# ANTHROPIC_API_KEY=
# YELP_API_KEY=
# GOOGLE_PLACES_API_KEY=

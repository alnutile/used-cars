# Client-side (VITE_ vars are PUBLIC — they ship in the browser bundle).
# The Supabase anon/publishable key is safe here. service_role NEVER goes in a VITE_ var.
# The app ships with working fallbacks for this project (src/lib/supabase.ts) —
# set these only to point a deployment at a different Supabase project.
VITE_SUPABASE_URL=https://szywiqaymwfunpstjjje.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

